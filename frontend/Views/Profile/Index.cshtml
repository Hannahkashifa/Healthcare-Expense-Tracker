@model ProfileViewModel
@{ ViewData["Title"] = "Profile"; }

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="profile-card">
            <div class="profile-header">
                <div class="profile-avatar">
                    @(string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName[0].ToString().ToUpper())
                </div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <p class="text-muted mb-0">@Model.Email</p>
            </div>
            <div class="profile-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form asp-action="Update" method="post" data-loading>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" readonly style="background:#f0f0f0" />
                    </div>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="Enter phone number" />
                    </div>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Date of Birth</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                    </div>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Gender</label>
                        <select asp-for="Gender" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="profile-info-row">
                        <label class="form-label fw-semibold">Member Since</label>
                        <p class="mb-0 text-muted">
                            <i class="bi bi-calendar3 me-1"></i>@Model.CreatedDate.ToString("dd MMMM yyyy")
                        </p>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 mt-3">
                        <i class="bi bi-check-lg me-2"></i>Update Profile
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
